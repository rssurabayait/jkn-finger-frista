# ===== Server =====
SERVER_PORT=3684
LOG_LEVEL=info

# ===== Identifikasi Mesin APM =====
# Nama unik untuk membedakan tiap mesin di log Telegram
# Contoh: APM-LOKET-01, APM-IGD-02, APM-RJ-03
MACHINE_NAME=APM-UNKNOWN

# ===== Telegram =====
# Dapatkan token dari @BotFather di Telegram
# Chat ID bisa group (diawali -100) atau personal
# TELEGRAM_ENABLED=false untuk matikan notifikasi
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Target: Aplikasi Sidik Jari BPJS (fp) =====
FP_WIN_TITLE=Aplikasi Registrasi Sidik Jari
FP_INS_PATH='C:\Program Files (x86)\BPJS Kesehatan\Aplikasi Sidik Jari BPJS Kesehatan\After.exe'
FP_USERNAME=
FP_PASSWORD=
FP_MOVE_LEFT=680
FP_MOVE_DOWN=600

# ===== Target: Aplikasi FRISTA =====
FRISTA_WIN_TITLE=Aplikasi FRISTA
FRISTA_INT_PATH='C:\frista\frista.exe'
FRISTA_USERNAME=
FRISTA_PASSWORD=
FRISTA_MOVE_LEFT=680
FRISTA_MOVE_DOWN=600