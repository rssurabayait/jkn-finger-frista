	"description": "Layanan HTTP lokal untuk mengendalikan Aplikasi Sidik Jari BPJS & FRISTA dari web APM/SIMRS",
	"type": "module",
	"main": "src/server.js",
	"author": {
		"name": "hatamidev",
		"email": "hatamidev@users.noreply.github.com"
	},
	"license": "MIT",
